# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=labpulse

# TCP Listener
TCP_HOST=0.0.0.0
TCP_PORT=9000

# Agent
SERVER_HOST=127.0.0.1
SERVER_PORT=9000
AGENT_INTERVAL=10

# Alerts
CPU_ALERT_THRESHOLD=85
RAM_ALERT_THRESHOLD=85
DISK_ALERT_THRESHOLD=90

# Offline Detection
OFFLINE_TIMEOUT_SECONDS=60